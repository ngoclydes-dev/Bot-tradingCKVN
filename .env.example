# Copy file này thành ".env" rồi điền thông tin thật, KHÔNG commit file .env lên git.

# Lấy từ @BotFather trên Telegram khi tạo bot mới
TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID của bạn hoặc group/channel sẽ nhận tín hiệu (dùng @userinfobot để lấy ID cá nhân,
# hoặc thêm bot vào group rồi gọi API getUpdates để lấy group chat_id, thường là số âm)
TELEGRAM_CHAT_ID=123456789

# (Tùy chọn) API key Anthropic để bật phân tích AI tin tức bằng Claude.
# Nếu để trống, bot tự dùng phân tích rule-based theo từ khoá (vẫn chạy được, kém chính xác hơn).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
